# Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Keys
# OpenAI API Key for AI-powered itinerary generation and chat
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key

# Google Maps API Key for location services
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OpenWeatherMap API Key for weather forecasts
# Get from: https://openweathermap.org/api
VITE_WEATHER_API_KEY=your_weather_api_key

# ExchangeRate-API Key for currency conversion